<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/1.20/owo-ui.xsd">
    <components>
        <flow-layout direction="vertical">
            <children>
                <flow-layout direction="vertical">
                    <children>
                        <label>
                            <text>Chat Improver</text>
                        </label>
                    </children>
                    <horizontal-alignment>center</horizontal-alignment>
                    <vertical-alignment>center</vertical-alignment>
                    <sizing>
                        <horizontal method="fill">100</horizontal>
                        <vertical method="fill">8</vertical>
                    </sizing>
                </flow-layout>

                <scroll direction="vertical">
                    <flow-layout direction="vertical">
                        <children>
                            <flow-layout direction="vertical" id="container">
                                <children/>
                                <horizontal-alignment>center</horizontal-alignment>
                                <vertical-alignment>center</vertical-alignment>
                                <sizing>
                                    <horizontal method="fill">60</horizontal>
                                </sizing>
                            </flow-layout>
                            <button id="btn_add_more">
                                <text>Добавить</text>
                                <tooltip-text>Добавить новую категорию</tooltip-text>
                                <margins>
                                    <top>8</top>
                                </margins>
                            </button>
                        </children>
                        <horizontal-alignment>center</horizontal-alignment>
                        <vertical-alignment>top</vertical-alignment>
                        <padding>
                            <top>20</top>
                            <bottom>20</bottom>
                        </padding>
                        <sizing>
                            <horizontal method="fill">100</horizontal>
                        </sizing>
                        <surface>
                            <blur quality="4" size="6"/>
                        </surface>
                    </flow-layout>

                    <sizing>
                        <horizontal method="fill">100</horizontal>
                        <vertical method="fill">84</vertical>
                    </sizing>
                    <scrollbar><vanilla-flat/></scrollbar>
                    <scrollbar-thiccness>8</scrollbar-thiccness>
                </scroll>

                <flow-layout direction="horizontal">
                    <children>
                        <button id="btn_close">
                            <text>Закрыть</text>
                            <margins>
                                <left>30</left>
                                <right>30</right>
                            </margins>
                            <sizing>
                                <horizontal method="fixed">96</horizontal>
                                <vertical method="fixed">28</vertical>
                            </sizing>
                        </button>
                        <button id="btn_save">
                            <text>Сохранить</text>
                            <margins>
                                <left>30</left>
                                <right>30</right>
                            </margins>
                            <sizing>
                                <horizontal method="fixed">96</horizontal>
                                <vertical method="fixed">28</vertical>
                            </sizing>
                        </button>
                    </children>
                    <horizontal-alignment>center</horizontal-alignment>
                    <vertical-alignment>center</vertical-alignment>
                    <sizing>
                        <horizontal method="fill">100</horizontal>
                        <vertical method="fill">8</vertical>
                    </sizing>
                </flow-layout>
            </children>
            <vertical-alignment>center</vertical-alignment>
            <horizontal-alignment>center</horizontal-alignment>
            <surface>
                <blur quality="4" size="6"/>
                <vanilla-translucent/>
            </surface>
        </flow-layout>
    </components>
</owo-ui>