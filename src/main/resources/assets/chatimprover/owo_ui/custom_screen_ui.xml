<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/1.20/owo-ui.xsd">
    <components>
        <flow-layout direction="vertical">
            <children>
                <flow-layout direction="vertical">
                    <children>
                        <label id="title"/>
                    </children>
                    <horizontal-alignment>center</horizontal-alignment>
                    <vertical-alignment>center</vertical-alignment>
                    <sizing>
                        <horizontal method="fill">100</horizontal>
                        <vertical method="fill">10</vertical>
                    </sizing>
                </flow-layout>

                <flow-layout direction="horizontal" id="container">
                    <children/>
                    <horizontal-alignment>center</horizontal-alignment>
                    <vertical-alignment>top</vertical-alignment>
                    <padding>
                        <all>20</all>
                    </padding>
                    <sizing>
                        <horizontal method="fill">100</horizontal>
                        <vertical method="fill">90</vertical>
                    </sizing>
                </flow-layout>
            </children>
            
            <vertical-alignment>center</vertical-alignment>
            <horizontal-alignment>center</horizontal-alignment>
            <surface>
                <blur quality="4" size="6"/>
                <vanilla-translucent/>
            </surface>
        </flow-layout>
    </components>
</owo-ui>